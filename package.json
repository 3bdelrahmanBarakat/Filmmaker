{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||''; if(!/^pnpm\\//.test(ua)){console.error('Use pnpm instead');process.exit(1)}\"",
    "build": "pnpm -r --filter \"./artifacts/**\" run build",
    "build:vercel": "pnpm -r --filter '@workspace/yousef-sediq' run build && cp -r artifacts/yousef-sediq/dist public",
    "typecheck": "pnpm -r --filter \"./artifacts/**\" --if-present run typecheck"
  },
  "private": true,
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.1"
  },
  "devDependencies": {
    "prettier": "^3.9.4",
    "typescript": "~5.9.3"
  }
}
